# Copy this file to `.env` and fill in your Supabase project values.
# Get them from: Supabase Dashboard -> Project Settings -> API Keys.
#
# BOTH must be prefixed with VITE_ so Vite exposes them to the frontend.
#
# VITE_SUPABASE_PUBLISHABLE_KEY is the new "publishable" key (starts with
# sb_publishable_...). It is PUBLIC and safe to ship *because* Row-Level Security
# is on. It replaces the older "anon public" key.
#
# NEVER put a SECRET key here (sb_secret_... or the legacy service_role) — those
# bypass security and must stay out of the frontend and out of git.
#
# In production, set these same two vars in:
#   Cloudflare Pages -> your project -> Settings -> Environment variables.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
